#!/bin/bash
# Install ouija from crates.io, clean local build artifacts, restart daemon
set -euo pipefail

echo "Fetching latest version from crates.io..."
LATEST=$(cargo search ouija 2>/dev/null | head -1 | sed 's/.*= "\(.*\)".*/\1/')
if [ -z "$LATEST" ]; then
    echo "error: could not find ouija on crates.io"
    exit 1
fi
echo "Installing ouija $LATEST..."
cargo install ouija --version "$LATEST" --force

echo "Cleaning local build artifacts..."
cargo clean

ouija stop 2>/dev/null || true
sleep 1

# Copy to wherever ouija is on PATH
OUIJA_BIN=$(which ouija 2>/dev/null || echo "$HOME/.local/bin/ouija")
CARGO_BIN="$HOME/.cargo/bin/ouija"
if [ "$OUIJA_BIN" != "$CARGO_BIN" ] && [ -f "$CARGO_BIN" ]; then
    cp "$CARGO_BIN" "$OUIJA_BIN"
fi

ouija start
echo "Running published build: $(ouija --version)"
