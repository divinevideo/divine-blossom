FROM rust:latest AS builder
WORKDIR /app
COPY Cargo.toml Cargo.lock ./
COPY src/ src/
COPY hooks/ hooks/
COPY scripts/ scripts/
COPY skills/ skills/
COPY opencode-plugin/ opencode-plugin/
COPY .mcp.json ./
RUN cargo test 2>&1
RUN cargo build --release 2>&1

FROM rust:latest
RUN apt-get update && apt-get install -y --no-install-recommends \
    tmux curl procps jq \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/ouija /usr/local/bin/ouija
COPY --from=builder /app/target/release/human_dm_helper /usr/local/bin/human-dm-helper
# Fake claude binary so daemon startup check passes (handles --version)
RUN printf '#!/bin/bash\nif [ "$1" = "--version" ]; then echo "claude-fake 0.0.0"; exit 0; fi\nexec sleep 3600\n' > /usr/local/bin/claude && chmod +x /usr/local/bin/claude
COPY tests/e2e/lib.sh /lib.sh
COPY tests/e2e/run-nostr-tests.sh /run-nostr-tests.sh
RUN chmod +x /run-nostr-tests.sh

ENTRYPOINT ["/run-nostr-tests.sh"]
